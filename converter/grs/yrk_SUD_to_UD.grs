include "SUD_to_UD.grs"

strat yrk_SUD_to_UD_main {
	Seq(
  	u_main,
	  Onf (yrk_post),
	)
}

package yrk_post {
	rule unknown_extensions {
		pattern { e: X -[dep:comp|acl:poss]-> Y }
		commands {
			del_feat e.2;
		}
	}

  rule Cyrillic {
		pattern { X[lemma = "ӈа"]}
		commands { X.lemma = "ӈa"}
	}

}
